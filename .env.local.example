# Evomi API key (from https://my.evomi.com/settings/api)
EVOMI_API_KEY=your_evomi_api_key_here

# Discord OAuth (from https://discord.com/developers/applications)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# NextAuth (generate a random string: openssl rand -base64 32)
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=http://localhost:3000
